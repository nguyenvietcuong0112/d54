<?xml version="1.0" encoding="utf-8"?>
<com.google.android.gms.ads.nativead.NativeAdView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/native_ad_view"
    android:background="#181818"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="120dp"
        app:cardCornerRadius="10dp"
        app:cardBackgroundColor="#181818"
        app:strokeColor="#2C2C2C">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#00000000"
            android:padding="8dp">

            <!-- Left Media Container (rounded 8dp) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_media"
                android:layout_width="128dp"
                android:layout_height="0dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <com.google.android.gms.ads.nativead.MediaView
                    android:id="@+id/ad_media"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

            </com.google.android.material.card.MaterialCardView>

            <!-- Floating Ad Badge at top-left of Media -->
            <TextView
                android:id="@+id/ad_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/ad_text"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:text="Ad"
                android:textColor="#A8B2C6"
                android:textSize="11sp"
                android:textStyle="bold"
                android:elevation="5dp"
                android:layout_marginTop="4dp"
                android:layout_marginStart="4dp"
                app:layout_constraintTop_toTopOf="@id/card_media"
                app:layout_constraintStart_toStartOf="@id/card_media" />

            <!-- Right App Icon Container -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_icon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="12dp"
                app:cardCornerRadius="6dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#D4DFE9"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toEndOf="@id/card_media">

                <ImageView
                    android:id="@+id/ad_app_icon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:adjustViewBounds="true"
                    android:src="@mipmap/ic_launcher" />

            </com.google.android.material.card.MaterialCardView>

            <!-- Headline/Title next to App Icon -->
            <TextView
                android:id="@+id/ad_headline"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:singleLine="true"
                android:textColor="@color/gnt_white"
                android:textSize="13sp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="@id/card_icon"
                app:layout_constraintBottom_toBottomOf="@id/card_icon"
                app:layout_constraintStart_toEndOf="@id/card_icon"
                app:layout_constraintEnd_toEndOf="parent"
                android:text="Loading..." />

            <!-- Description/Body Text -->
            <TextView
                android:id="@+id/ad_body"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:textColor="@color/gnt_white"
                android:textSize="11sp"
                app:layout_constraintTop_toBottomOf="@id/card_icon"
                app:layout_constraintStart_toStartOf="@id/card_icon"
                app:layout_constraintEnd_toEndOf="parent"
                android:text="loading...." />

            <!-- Action Button / CTA -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/ad_call_to_action"
                android:layout_width="0dp"
                android:layout_height="30dp"
                android:background="@drawable/bg_button_ads"
                android:gravity="center"
                android:text="Open"
                android:textColor="@color/gnt_white"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="@id/card_icon"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>
</com.google.android.gms.ads.nativead.NativeAdView>
